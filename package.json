{
  "name": "obsidian-reminder-plugin",
  "version": "1.2.1",
  "description": "Reminder plugin for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs watch",
    "build": "node esbuild.config.mjs production",
    "lint": "eslint && tsc --noEmit --pretty && svelte-check",
    "lint:fix": "eslint --fix && tsc --noEmit --pretty && svelte-check",
    "test": "jest"
  },
  "keywords": [],
  "author": "uphy",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@codemirror/commands": "6.10.2",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@tsconfig/svelte": "^5.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "builtin-modules": "^5.3.0",
    "cross-env": "^10.1.0",
    "electron": "^39.8.10",
    "esbuild": "^0.28.1",
    "esbuild-svelte": "^0.9.5",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-svelte": "^3.20.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "moment": "^2.30.1",
    "obsidian": "^1.13.1",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte-check": "^4.7.2",
    "svelte-preprocess": "^6.0.5",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "rrule": "^2.8.1",
    "svelte": "^5.56.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testEnvironment": "jsdom",
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/*.test.ts"
    ],
    "preset": "ts-jest/presets/default-esm"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-svelte"
    ],
    "overrides": [
      {
        "files": "*.svelte",
        "options": {
          "parser": "svelte"
        }
      }
    ]
  }
}
